# ==============================================================================
# Quran LMS Production Environment Variables Template
# ==============================================================================
# Copy this file to '.env' at the root of the project for production deployment:
# cp .env.example .env
# Make sure to change all default secrets/passwords!

# ------------------------------------------------------------------------------
# 1. Database Configuration (PostgreSQL)
# ------------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_production_db_password_change_me
POSTGRES_DB=quran_lms
# Note: DATABASE_URL must reference the service name 'postgres' inside the Docker network
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public

# ------------------------------------------------------------------------------
# 2. Redis Configuration (for BullMQ queues)
# ------------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# 3. NestJS Backend Configuration
# ------------------------------------------------------------------------------
PORT=4000
NODE_ENV=production

# JWT Authentication (generate strong random strings)
JWT_SECRET=super_secret_jwt_sign_key_change_me_in_prod_at_least_32_chars
JWT_REFRESH_SECRET=super_secret_jwt_refresh_key_change_me_in_prod_at_least_32_chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS Allowed Origins (Comma-separated list of origins)
# For domain 'quran-lms.kpcybers.com', allow the frontend domain
CORS_ORIGIN=https://quran-lms.kpcybers.com

# Gemini AI API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Speech-to-Text Vosk service URL (internal service name in docker-compose)
VOSK_SERVER_URL=ws://vosk:2700

# Directory inside the container where class recordings are processed
RECORDINGS_DIR=/app/recordings

# ------------------------------------------------------------------------------
# 4. LiveKit Configuration
# ------------------------------------------------------------------------------
# API keys used by the NestJS app to generate join tokens and communicate with LiveKit
LIVEKIT_API_KEY=livekit_prod_api_key_generate_me
LIVEKIT_API_SECRET=livekit_prod_api_secret_generate_me

# Internally accessible LiveKit URL for the backend container (host gateway)
LIVEKIT_HOST=http://host.docker.internal:7880

# Publicly accessible LiveKit WebSocket URL (grey-clouded subdomain in Cloudflare)
LIVEKIT_PUBLIC_URL=wss://livekit.kpcybers.com

# ------------------------------------------------------------------------------
# 5. Next.js Frontend Configuration (Baked at Build Time)
# ------------------------------------------------------------------------------
# Public API URL used by the client-side code
NEXT_PUBLIC_API_URL=https://quran-lms.kpcybers.com/api/v1
# Public LiveKit URL (unused by frontend directly, but defined in codebase env specs)
NEXT_PUBLIC_LIVEKIT_URL=wss://livekit.kpcybers.com

# ------------------------------------------------------------------------------
# 6. Google Drive Storage Integration (Optional)
# ------------------------------------------------------------------------------
# If omitted, files will remain in local recordings storage only
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=https://developers.google.com/oauthplayground
GOOGLE_DRIVE_REFRESH_TOKEN=

# ------------------------------------------------------------------------------
# 7. Host Port Bindings (Production Security Hardening)
# ------------------------------------------------------------------------------
# In production, we restrict host-accessible ports to loopback (127.0.0.1)
# so they are not exposed to the public internet. External requests must go
# through the Nginx reverse proxy.
# In local development, you can comment these or leave them as 0.0.0.0 (default).
POSTGRES_PORT_BINDING=127.0.0.1:5432:5432
REDIS_PORT_BINDING=127.0.0.1:6379:6379
NESTJS_PORT_BINDING=127.0.0.1:4000:4000
NEXTJS_PORT_BINDING=127.0.0.1:3000:3000
# Vosk STT is only used internally by the backend container; do not bind to any host IP
VOSK_PORT_BINDING=127.0.0.1:2700:2700
